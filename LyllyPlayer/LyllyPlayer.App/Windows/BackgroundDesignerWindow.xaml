<Window x:Class="LyllyPlayer.Windows.BackgroundDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:LyllyPlayer"
        Title="Background designer"
        Icon="pack://application:,,,/Assets/LyllyPlayer.ico"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Width="860"
        Height="560"
        MinWidth="860"
        MinHeight="560"
        MaxWidth="860"
        MaxHeight="560"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Foreground="{DynamicResource App.Theme.Foreground}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
          UseLayoutRounding="True"
          local:RoundedChromeClip.IsEnabled="True">
        <!-- Use semantic theme surfaces (updated for Default/Windows themes). App.Brush.WindowBg is a legacy near-black constant and does not track light theme. -->
        <Border Background="{DynamicResource App.Theme.Surface}"
                BorderThickness="0"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
        <Grid Margin="{DynamicResource App.Theme.WindowChromeContentMargin}">
            <Border SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                    UseLayoutRounding="True"
                    Background="{DynamicResource App.Theme.SurfaceRaised}"
                    CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>

            <local:WindowChromeFrameRing Panel.ZIndex="5"
                                         SnapsToDevicePixels="True"
                                         StrokeWidth="{DynamicResource App.Theme.WindowChromeStrokeWidth}"
                                         OuterCornerRadius="8">
                <local:WindowChromeFrameRing.Style>
                    <Style TargetType="{x:Type local:WindowChromeFrameRing}">
                        <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderActive}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderInactive}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:WindowChromeFrameRing.Style>
            </local:WindowChromeFrameRing>

            <Grid Background="Transparent"
                  Panel.ZIndex="10"
                  LayoutTransform="{DynamicResource App.UiScaleTransform}"
                  TextElement.Foreground="{DynamicResource App.Theme.Foreground}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="ChromeBar"
                        Grid.Row="0"
                        VerticalAlignment="Top"
                        Margin="{DynamicResource App.Theme.WindowBorderThicknessNegativeSides}"
                        Padding="{DynamicResource App.Theme.WindowChromeTitleBarPadding}"
                        CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuterTopOnly}"
                        SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                        UseLayoutRounding="True"
                        ClipToBounds="True"
                        Panel.ZIndex="999"
                        MouseLeftButtonDown="ChromeBar_OnMouseLeftButtonDown">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Height="28"
                          Margin="{DynamicResource App.Theme.WindowChromeTitleBarContentMargin}"
                          Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Background designer"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Grid.Column="1"
                                Width="34"
                                Height="24"
                                Margin="0,2,0,2"
                                Padding="0"
                                FontFamily="{StaticResource App.MonoFont}"
                                FontSize="12"
                                Content="[X]"
                                Click="ChromeCloseButton_OnClick">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="12,12,12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="6"
                            Padding="10"
                            Background="{DynamicResource App.Theme.SurfaceRaised}"
                            BorderBrush="{DynamicResource App.Theme.Border}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Window:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox x:Name="TargetComboBox"
                                          Width="200"
                                          Height="28"
                                          Foreground="{DynamicResource App.Theme.Foreground}"
                                          SelectionChanged="TargetComboBox_OnSelectionChanged">
                                    <ComboBoxItem Content="Main" Tag="Main" IsSelected="True"/>
                                    <ComboBoxItem Content="Playlist" Tag="Playlist"/>
                                    <ComboBoxItem Content="Options / Log" Tag="OptionsLog"/>
                                </ComboBox>
                            </StackPanel>

                            <Grid Grid.Row="1" ClipToBounds="True" Background="Transparent">
                                <Grid x:Name="PreviewHostGrid" Background="Transparent" SizeChanged="PreviewHostGrid_OnSizeChanged">
                                    <Image x:Name="PreviewImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Canvas x:Name="OverlayCanvas" IsHitTestVisible="True" Background="Transparent">
                                        <!-- Default bounds outline (shown while editing Main Compact/Ultra). Drawn as a crisp double-stroke:
                                             thick dark underlay + thin light dashed overlay so it stays visible on any background. -->
                                        <Rectangle x:Name="MainOutlineRectShadow"
                                                   Stroke="{DynamicResource App.Theme.Border}"
                                                   StrokeThickness="4"
                                                   Fill="Transparent"
                                                   Visibility="Collapsed"
                                                   IsHitTestVisible="False"/>
                                        <Rectangle x:Name="MainOutlineRect"
                                                   Stroke="{DynamicResource App.Theme.ForegroundSubtle}"
                                                   StrokeThickness="1.5"
                                                   StrokeDashArray="2 2"
                                                   Fill="Transparent"
                                                   Visibility="Collapsed"/>
                                        <!-- Selection adorner: moved/sized as a single unit to avoid Thumb jitter -->
                                        <Grid x:Name="SelectionAdorner"
                                              Width="100"
                                              Height="60">
                                            <Rectangle x:Name="SelectionRect"
                                                       Stroke="{DynamicResource App.Theme.Accent}"
                                                       StrokeThickness="2"
                                                       Fill="{DynamicResource App.Theme.Selection}"
                                                       IsHitTestVisible="False"/>
                                            <!-- Drag anywhere inside selection -->
                                            <Thumb x:Name="SelectionThumb"
                                                   DragDelta="SelectionThumb_OnDragDelta"
                                                   Cursor="SizeAll"
                                                   Opacity="0"
                                                   Background="Transparent"/>
                                            <!-- Resize handle (bottom-right) -->
                                            <Thumb x:Name="ResizeThumb"
                                                   DragStarted="ResizeThumb_OnDragStarted"
                                                   DragDelta="ResizeThumb_OnDragDelta"
                                                   DragCompleted="ResizeThumb_OnDragCompleted"
                                                   Cursor="SizeNWSE"
                                                   Width="18"
                                                   Height="18"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Background="Transparent">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                        <Grid>
                                                            <Rectangle Fill="Transparent"/>
                                                            <Path Data="M 0 18 L 18 0 L 18 18 Z"
                                                                  Fill="{DynamicResource App.Theme.ForegroundSubtle}"
                                                                  Stroke="{DynamicResource App.Theme.Border}"
                                                                  StrokeThickness="0.5"
                                                                  Stretch="Fill"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Grid>
                                    </Canvas>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Main mode"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <StackPanel x:Name="MainModePanel" Margin="0,0,0,12">
                            <RadioButton x:Name="MainModeDefaultRadio" GroupName="MainMode" Content="Default" IsChecked="True" Checked="MainModeRadio_OnChecked" Margin="0,0,0,4"/>
                            <RadioButton x:Name="MainModeCompactRadio" GroupName="MainMode" Content="Compact" Checked="MainModeRadio_OnChecked" Margin="0,0,0,4"/>
                            <RadioButton x:Name="MainModeUltraRadio" GroupName="MainMode" Content="Ultra compact" Checked="MainModeRadio_OnChecked"/>
                        </StackPanel>

                        <TextBlock Text="Zoom" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Slider x:Name="ZoomSlider" Minimum="0.05" Maximum="1" Value="1"
                                ValueChanged="ZoomSlider_OnValueChanged"/>
                        <TextBlock x:Name="ZoomValueText" FontSize="11" Foreground="{DynamicResource App.Theme.ForegroundSubtle}" Margin="0,4,0,12" Text="100%"/>

                        <CheckBox x:Name="LockAspectRatioCheckBox"
                                  Content="Lock aspect ratio"
                                  IsChecked="True"
                                  Margin="0,0,0,12"
                                  Checked="LockAspectRatioCheckBox_OnChecked"
                                  Unchecked="LockAspectRatioCheckBox_OnUnchecked"/>

                        <Button Content="Reset (full image)" Height="30" Margin="0,0,0,8" Click="ResetButton_OnClick"/>
                        <Button Content="Copy from Default → Compact/Ultra" Height="30" Margin="0,0,0,16" Click="CopyFromDefaultButton_OnClick"/>

                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource App.Theme.ForegroundSubtle}"
                                   Text="Drag the box to pick the image area. Use Zoom to shrink/grow the box around its center. For Main: Compact/Ultra are constrained inside Default."/>
                    </StackPanel>
                </Grid>

                <DockPanel Grid.Row="2" Margin="12,0,12,12" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                TextElement.Foreground="{DynamicResource App.Theme.Foreground}">
                        <Button x:Name="ApplyButton" Content="Apply" MinWidth="90" Height="30" Margin="0,0,8,0" Click="ApplyButton_OnClick"/>
                        <Button x:Name="OkButton" Content="OK" MinWidth="90" Height="30" Margin="0,0,8,0" Click="OkButton_OnClick"/>
                        <Button x:Name="CancelButton" Content="Cancel" MinWidth="90" Height="30" Click="CancelButton_OnClick"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>

