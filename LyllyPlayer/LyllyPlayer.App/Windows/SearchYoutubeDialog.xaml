<Window x:Class="LyllyPlayer.Windows.SearchYoutubeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:LyllyPlayer"
        Title="Search Youtube"
        Icon="pack://application:,,,/Assets/LyllyPlayer.ico"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Width="520"
        Height="285"
        MinWidth="420"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
          UseLayoutRounding="True"
          local:RoundedChromeClip.IsEnabled="True">
        <Border Background="{DynamicResource App.Brush.WindowBg}"
                BorderThickness="0"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
        <Grid Margin="{DynamicResource App.Theme.WindowChromeContentMargin}">
            <Border SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                    UseLayoutRounding="True"
                    Background="{DynamicResource App.Brush.WindowBgImage.OptionsLog}"
                    CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
            <local:WindowChromeFrameRing Panel.ZIndex="5"
                                         SnapsToDevicePixels="True"
                                         StrokeWidth="{DynamicResource App.Theme.WindowChromeStrokeWidth}"
                                         OuterCornerRadius="8">
                <local:WindowChromeFrameRing.Style>
                    <Style TargetType="{x:Type local:WindowChromeFrameRing}">
                        <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderActive}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderInactive}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:WindowChromeFrameRing.Style>
            </local:WindowChromeFrameRing>
            <Grid Background="Transparent"
                  Panel.ZIndex="10"
                  LayoutTransform="{DynamicResource App.UiScaleTransform}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Border x:Name="ChromeBar"
                Grid.Row="0"
                VerticalAlignment="Top"
                Margin="{DynamicResource App.Theme.WindowBorderThicknessNegativeSides}"
                Padding="{DynamicResource App.Theme.WindowChromeTitleBarPadding}"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuterTopOnly}"
                SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                UseLayoutRounding="True"
                ClipToBounds="True"
                Panel.ZIndex="999"
                MouseLeftButtonDown="ChromeBar_OnMouseLeftButtonDown">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarActive}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                            <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarInactive}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Height="28"
                  Margin="{DynamicResource App.Theme.WindowChromeTitleBarContentMargin}"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button x:Name="ChromeCloseButton" Grid.Column="1"
                        Width="34"
                        Height="24"
                        Margin="0,2,0,2"
                        Padding="0"
                        FontFamily="{StaticResource App.MonoFont}"
                        FontSize="12"
                        Content="[X]"
                        Click="CloseButton_OnClick">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="{DynamicResource App.Theme.WindowChromeBodyInsetMargin}">
        <Border Margin="12,12,12,12"
                CornerRadius="6"
                Padding="10"
                Background="{DynamicResource App.Theme.Surface}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Search query"
                           Foreground="{DynamicResource App.Theme.Foreground}"
                           Margin="0,0,0,6"/>
                <TextBox Grid.Row="1"
                         x:Name="QueryTextBox"
                         Height="30"
                         VerticalContentAlignment="Center"
                         KeyDown="QueryTextBox_OnKeyDown"/>

                <TextBlock Grid.Row="2"
                           Text="Minimum length"
                           Foreground="{DynamicResource App.Theme.Foreground}"
                           Margin="0,10,0,6"/>
                <ComboBox Grid.Row="3"
                          x:Name="MinLengthComboBox"
                          Height="30"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Any"/>
                    <ComboBoxItem Content="30 sec"/>
                    <ComboBoxItem Content="1 min"/>
                    <ComboBoxItem Content="2 min"/>
                </ComboBox>

                <Grid Grid.Row="4" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Result count"
                                   Foreground="{DynamicResource App.Theme.ForegroundSubtle}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="CountTextBox"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 Text="50"
                                 KeyDown="QueryTextBox_OnKeyDown"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button MinWidth="84" Margin="0,0,8,0" Content="Cancel" Click="CancelButton_OnClick"/>
                        <Button MinWidth="84" Content="Load" Click="LoadButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>

