<UserControl x:Class="LyllyPlayer.Windows.LocalFilesTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LyllyPlayer"
             Background="Transparent">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button x:Name="AddFolderButton"
                    Content="Add folder…"
                    MinWidth="120"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="AddFolderButton_OnClick"/>
            <Button x:Name="AddFilesButton"
                    Content="Add files…"
                    MinWidth="120"
                    Height="32"
                    Click="AddFilesButton_OnClick"/>
        </StackPanel>

        <GroupBox Grid.Row="1"
                  Header="Import behavior"
                  Margin="0,8,0,0"
                  Foreground="{DynamicResource App.Theme.Foreground}"
                  BorderBrush="{DynamicResource App.Theme.Border}">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="ReplaceRadio"
                                 GroupName="ImportBehavior"
                                 Content="Replace"
                                 Margin="0,0,14,0"
                                 Checked="ReplaceRadio_OnChecked"/>
                    <RadioButton x:Name="AppendRadio"
                                 GroupName="ImportBehavior"
                                 Content="Append"
                                 Checked="AppendRadio_OnChecked"/>
                </StackPanel>
                <CheckBox x:Name="RemoveDuplicatesCheckBox"
                          Content="Remove duplicates (full path + file name)"
                          Checked="RemoveDuplicatesCheckBox_OnChecked"
                          Unchecked="RemoveDuplicatesCheckBox_OnUnchecked"/>
            </StackPanel>
        </GroupBox>

        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Padding="8"
                CornerRadius="6"
                Background="{DynamicResource App.Theme.SurfaceRaised}"
                BorderBrush="{DynamicResource App.Theme.Border}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <Button x:Name="CancelButton"
                        DockPanel.Dock="Right"
                        Content="Cancel"
                        MinWidth="80"
                        Height="28"
                        Margin="8,0,0,0"
                        Visibility="Collapsed"
                        Click="CancelButton_OnClick"/>
                <Button x:Name="SkipMetadataButton"
                        DockPanel.Dock="Right"
                        Content="Skip metadata"
                        MinWidth="110"
                        Height="28"
                        Margin="8,0,0,0"
                        Visibility="Collapsed"
                        Click="SkipMetadataButton_OnClick"/>
                <TextBlock x:Name="StatusTextBlock"
                           Text="Ready."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource App.Theme.Foreground}"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

