<Window x:Class="LyllyPlayer.Windows.PlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:LyllyPlayer"
        Title="LyllyPlayer — Playlist"
        Icon="pack://application:,,,/Assets/LyllyPlayer.ico"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Width="760"
        Height="720"
        MinHeight="320"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        >
        <!-- Window MinWidth set by MainWindow code-behind to 560.0 * UiScale -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8,0,8,8"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
          UseLayoutRounding="True"
          local:RoundedChromeClip.IsEnabled="True">
        <Border Background="{DynamicResource App.Brush.WindowBg}"
                BorderThickness="0"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
        <Grid Margin="{DynamicResource App.Theme.WindowChromeContentMargin}">
            <Border SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                    UseLayoutRounding="True"
                    Background="{DynamicResource App.Brush.WindowBgImage.Playlist}"
                    CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
            <local:WindowChromeFrameRing Panel.ZIndex="5"
                                         SnapsToDevicePixels="True"
                                         StrokeWidth="{DynamicResource App.Theme.WindowChromeStrokeWidth}"
                                         OuterCornerRadius="8">
                <local:WindowChromeFrameRing.Style>
                    <Style TargetType="{x:Type local:WindowChromeFrameRing}">
                        <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderActive}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderInactive}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:WindowChromeFrameRing.Style>
            </local:WindowChromeFrameRing>
            <Grid Background="Transparent"
                  Panel.ZIndex="10"
                  LayoutTransform="{DynamicResource App.UiScaleTransform}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- Custom top bar -->
        <Border x:Name="ChromeBar"
                Grid.Row="0"
                VerticalAlignment="Top"
                Margin="{DynamicResource App.Theme.WindowBorderThicknessNegativeSides}"
                Padding="{DynamicResource App.Theme.WindowChromeTitleBarPadding}"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuterTopOnly}"
                SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                UseLayoutRounding="True"
                ClipToBounds="True"
                Panel.ZIndex="999"
                MouseLeftButtonDown="ChromeBar_OnMouseLeftButtonDown">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarActive}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                            <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarInactive}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Height="28"
                  Margin="{DynamicResource App.Theme.WindowChromeTitleBarContentMargin}"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button x:Name="ChromeCloseButton" Grid.Column="1"
                        Width="34"
                        Height="24"
                        Margin="0,2,0,2"
                        Padding="0"
                        FontFamily="{StaticResource App.MonoFont}"
                        FontSize="12"
                        Content="[X]"
                        Click="ChromeCloseButton_OnClick">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="{DynamicResource App.Theme.WindowChromeBodyInsetMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

         <Grid Grid.Row="0" Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="RefreshButton"
                    Content="&#x21BB;"
                    MinWidth="44"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="RefreshButton_OnClick"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="SavePlaylistButton"
                        Content="Save playlist..."
                        MinWidth="110"
                        Height="30"
                        Margin="0,0,6,0"
                        Click="SavePlaylistButton_OnClick"/>
                <Button x:Name="LoadPlaylistButton"
                        Content="Load playlist..."
                        MinWidth="110"
                        Height="30"
                        Margin="0,0,6,0"
                        Click="LoadPlaylistButton_OnClick"/>
                <Button x:Name="SearchYoutubeButton"
                        Content="Youtube..."
                        MinWidth="108"
                        Height="30"
                        Margin="0,0,6,0"
                        Click="SearchYoutubeButton_OnClick"/>
                <Button x:Name="LoadFolderButton"
                        Content="Local files..."
                        MinWidth="104"
                        Height="30"
                        Click="LoadFolderButton_OnClick"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="1" Margin="12,8,12,0" Orientation="Horizontal">
            <TextBlock Text="Sort"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <ToggleButton x:Name="SortDescToggleButton"
                          Width="70"
                          Height="28"
                          Margin="0,0,8,0"
                          Content="Asc"
                          Checked="SortDescToggleButton_OnChecked"
                          Unchecked="SortDescToggleButton_OnUnchecked"/>
            <ComboBox x:Name="SortModeComboBox"
                      Width="170"
                      Height="28"
                      Margin="0,0,8,0"
                      Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                      Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                      BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                      VerticalContentAlignment="Center"
                      SelectionChanged="SortModeComboBox_OnSelectionChanged"/>
            <Button x:Name="ApplySortButton"
                    Content="Sort"
                    MinWidth="62"
                    Height="28"
                    Margin="0,0,8,0"
                    Click="ApplySortButton_OnClick"/>
            <Button x:Name="CleanInvalidItemsButton"
                    Content="Clean invalid items"
                    MinWidth="148"
                    Height="28"
                    Margin="0,0,0,0"
                    Click="CleanInvalidItemsButton_OnClick"/>                    
        </StackPanel>

        <Grid Grid.Row="2" Margin="12,0,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="QueuedPanel"
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Padding="8"
                    CornerRadius="6"
                    Background="{DynamicResource App.Theme.SurfaceRaised}"
                    BorderBrush="{DynamicResource App.Theme.Border}"
                    BorderThickness="1"
                    MaxHeight="220"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="QueuedHeaderTextBlock"
                               Text="Queue"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource App.Theme.Foreground}"/>
                    <ListBox x:Name="QueuedListBox"
                             Grid.Row="1"
                             Background="Transparent"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Focusable="False"
                             PreviewMouseLeftButtonDown="QueueListBox_OnPreviewMouseLeftButtonDown"
                             MouseDoubleClick="QueueListBox_OnMouseDoubleClick">
                        <ListBox.Resources>
                            <ContextMenu x:Key="QueueItemContextMenuQueued"
                                         Opened="QueueItemContextMenu_OnOpened">
                                <MenuItem x:Name="OpenMenuItem"
                                          Header="Open"
                                          Click="OpenMenuItem_OnClick"/>
                                <Separator/>
                                <MenuItem x:Name="AddToQueueMenuItem"
                                          Header="Add to queue"
                                          Click="AddToQueueMenuItem_OnClick"/>
                                <MenuItem x:Name="RemoveFromQueueMenuItem"
                                          Header="Remove from queue"
                                          Click="RemoveFromQueueMenuItem_OnClick"/>
                            </ContextMenu>
                        </ListBox.Resources>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="ContextMenu" Value="{StaticResource QueueItemContextMenuQueued}"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Theme.Hover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Theme.Selection}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Theme.SelectionText}"/>
                                        <Setter Property="BorderThickness" Value="0,1,0,1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Foreground}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Theme.Pressed}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Theme.Foreground}"/>
                                        <Setter Property="BorderThickness" Value="0,1,0,1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Foreground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="{Binding SourceGlyph}"
                                               Width="18"
                                               Margin="0,0,6,0"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Opacity="0.85"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <ListBox x:Name="PlaylistListBox"
                     Grid.Row="1"
                     Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.IsDeferredScrollingEnabled="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Focusable="False"
                     PreviewMouseLeftButtonDown="QueueListBox_OnPreviewMouseLeftButtonDown"
                     MouseDoubleClick="QueueListBox_OnMouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="{Binding SourceGlyph}"
                                       Width="18"
                                       Margin="0,0,6,0"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Opacity="0.85"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayTitle}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Resources>
                    <ContextMenu x:Key="QueueItemContextMenu"
                                 Opened="QueueItemContextMenu_OnOpened">
                        <MenuItem x:Name="OpenMenuItem"
                                  Header="Open"
                                  Click="OpenMenuItem_OnClick"/>
                        <Separator/>
                        <MenuItem x:Name="AddToQueueMenuItem"
                                  Header="Add to queue"
                                  Click="AddToQueueMenuItem_OnClick"/>
                        <MenuItem x:Name="RemoveFromQueueMenuItem"
                                  Header="Remove from queue"
                                  Click="RemoveFromQueueMenuItem_OnClick"/>
                    </ContextMenu>
                </ListBox.Resources>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="ContextMenu" Value="{StaticResource QueueItemContextMenu}"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Focusable" Value="False"/>
                        <!-- Critical: remove default selection visuals -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          Margin="{TemplateBinding Padding}"
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsQueued}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceRaised}"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </DataTrigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Theme.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Theme.Selection}"/>
                                <Setter Property="BorderThickness" Value="0,1,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Foreground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource App.Theme.SelectionText}"/>
                            </Trigger>

                            <!-- Current track: neutral pressed surface (not Selection blue) -->
                            <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Theme.Pressed}"/>
                                <Setter Property="BorderThickness" Value="0,1,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Foreground}"/>                                
                                <Setter Property="Foreground" Value="{DynamicResource App.Theme.Foreground}"/>
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUnavailable}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceRaised}"/>
                                <Setter Property="Foreground" Value="{DynamicResource App.Theme.ForegroundSubtle}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Border}"/>
                                <Setter Property="Opacity" Value="0.55"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAgeRestricted}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceRaised}"/>
                                <Setter Property="Foreground" Value="{DynamicResource App.Theme.ForegroundSubtle}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Border}"/>
                                <Setter Property="Opacity" Value="0.7"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPremium}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceRaised}"/>
                                <Setter Property="Foreground" Value="{DynamicResource App.Theme.ForegroundSubtle}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Border}"/>
                                <Setter Property="Opacity" Value="0.55"/>
                            </DataTrigger>
                            <!-- Login-gated: slightly muted but still readable and playable with cookies -->
                            <DataTrigger Binding="{Binding RequiresCookies}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource App.Theme.ForegroundSubtle}"/>
                                <Setter Property="Opacity" Value="0.75"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <Border x:Name="BusyOverlay"
                    Background="Transparent"
                    CornerRadius="6"
                    ClipToBounds="True"
                    Visibility="Collapsed">
                <Grid>
                    <Border CornerRadius="6"
                            Background="{DynamicResource App.Theme.Surface}"
                            Opacity="0.92"
                            SnapsToDevicePixels="True"/>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="12">
                        <TextBlock x:Name="BusyOverlayText"
                                   Text="Loading..."
                                   Foreground="{DynamicResource App.Theme.Foreground}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="BusyOverlayProgressBar"
                                     Height="10"
                                     MinWidth="220"
                                     MaxWidth="360"
                                     Margin="0,10,0,0"
                                     HorizontalAlignment="Center"
                                     Visibility="Collapsed"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="0"
                                     Background="{DynamicResource App.Theme.Surface}"
                                     Foreground="{DynamicResource App.Theme.Accent}"
                                     BorderBrush="{DynamicResource App.Theme.Border}"
                                     BorderThickness="1"/>
                        <Button x:Name="BusyOverlaySkipFolderMetadataButton"
                                Margin="0,12,0,0"
                                Padding="14,8"
                                MaxWidth="320"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed"
                                Background="{DynamicResource App.Theme.SurfaceRaised}"
                                BorderBrush="{DynamicResource App.Theme.Border}"
                                BorderThickness="1"
                                Foreground="{DynamicResource App.Theme.Foreground}"
                                Click="BusyOverlaySkipFolderMetadataButton_OnClick">
                            <TextBlock Text="Taking too long? [Skip metadata]"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource App.Theme.Foreground}"
                                       FontSize="13"/>
                        </Button>
                        <Button x:Name="BusyOverlayStopSearchButton"
                                Margin="0,12,0,0"
                                Padding="14,8"
                                MaxWidth="320"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed"
                                Background="{DynamicResource App.Theme.SurfaceRaised}"
                                BorderBrush="{DynamicResource App.Theme.Border}"
                                BorderThickness="1"
                                Foreground="{DynamicResource App.Theme.Foreground}"
                                Click="BusyOverlayStopSearchButton_OnClick">
                            <TextBlock Text="Taking too long? [Stop search]"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource App.Theme.Foreground}"
                                       FontSize="13"/>
                        </Button>
                        <Button x:Name="BusyOverlayCancelButton"
                                Content="Cancel"
                                Margin="0,10,0,0"
                                Padding="18,6"
                                MinWidth="96"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed"
                                Background="{DynamicResource App.Theme.SurfaceRaised}"
                                BorderBrush="{DynamicResource App.Theme.Border}"
                                Foreground="{DynamicResource App.Theme.Foreground}"
                                Click="BusyOverlayCancelButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3"
                   Margin="12,0,12,12"
                   LastChildFill="True">
            <Button x:Name="PlaylistFilterClearButton"
                    DockPanel.Dock="Right"
                    Content="Clear"
                    MinWidth="56"
                    Height="32"
                    Margin="8,0,0,0"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Click="PlaylistFilterClearButton_OnClick"/>
            <TextBlock DockPanel.Dock="Left"
                       Text="Search:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource App.Theme.ForegroundSubtle}"/>
            <TextBox x:Name="PlaylistFilterTextBox"
                     Height="32"
                     Padding="6,0"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,0"
                     TextChanged="PlaylistFilterTextBox_TextChanged"/>
        </DockPanel>
        </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>


