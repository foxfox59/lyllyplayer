<Window x:Class="LyllyPlayer.Windows.YoutubeModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:LyllyPlayer"
        Title="LyllyPlayer — YouTube"
        Icon="pack://application:,,,/Assets/LyllyPlayer.ico"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Width="720"
        Height="560"
        MinWidth="600"
        MinHeight="460"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8,0,8,8"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
          UseLayoutRounding="True"
          local:RoundedChromeClip.IsEnabled="True">
        <Border Background="{DynamicResource App.Brush.WindowBg}"
                BorderThickness="0"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
        <Grid Margin="{DynamicResource App.Theme.WindowChromeContentMargin}">
            <Border SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                    UseLayoutRounding="True"
                    Background="{DynamicResource App.Brush.WindowBgImage.OptionsLog}"
                    CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
            <local:WindowChromeFrameRing Panel.ZIndex="5"
                                         SnapsToDevicePixels="True"
                                         StrokeWidth="{DynamicResource App.Theme.WindowChromeStrokeWidth}"
                                         OuterCornerRadius="8">
                <local:WindowChromeFrameRing.Style>
                    <Style TargetType="{x:Type local:WindowChromeFrameRing}">
                        <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderActive}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderInactive}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:WindowChromeFrameRing.Style>
            </local:WindowChromeFrameRing>

            <Grid Background="Transparent"
                  Panel.ZIndex="10"
                  LayoutTransform="{DynamicResource App.UiScaleTransform}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Custom top bar -->
                <Border x:Name="ChromeBar"
                        Grid.Row="0"
                        VerticalAlignment="Top"
                        Margin="{DynamicResource App.Theme.WindowBorderThicknessNegativeSides}"
                        Padding="{DynamicResource App.Theme.WindowChromeTitleBarPadding}"
                        CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuterTopOnly}"
                        SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                        UseLayoutRounding="True"
                        ClipToBounds="True"
                        Panel.ZIndex="999"
                        MouseLeftButtonDown="ChromeBar_OnMouseLeftButtonDown">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Height="28"
                          Margin="{DynamicResource App.Theme.WindowChromeTitleBarContentMargin}"
                          Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button x:Name="ChromeCloseButton" Grid.Column="1"
                                Width="34"
                                Height="24"
                                Margin="0,2,0,2"
                                Padding="0"
                                FontFamily="{StaticResource App.MonoFont}"
                                FontSize="12"
                                Content="[X]"
                                Click="CloseButton_OnClick">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="{DynamicResource App.Theme.WindowChromeBodyInsetMargin}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Import behavior"
                              Grid.Row="0"
                              Margin="12,12,12,8"
                              Foreground="{DynamicResource App.Brush.Text}"
                              BorderBrush="{DynamicResource App.Brush.Border}">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ReplaceRadioButton" Content="Replace playlist" IsChecked="True" Margin="0,0,16,0"/>
                            <RadioButton x:Name="AppendRadioButton" Content="Append" Margin="0,0,16,0"/>
                            <CheckBox x:Name="GlobalDedupeCheckBox" Content="Remove duplicates" IsChecked="True"/>
                        </StackPanel>
                    </GroupBox>

                    <TabControl Grid.Row="1" Margin="12,0,12,12">
            <TabItem Header="Search videos">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Query"/>
                    <TextBox x:Name="SearchVideosQueryTextBox" Grid.Row="0" Grid.Column="1" Height="32" MinWidth="360" HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center" Padding="8,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,8,0" Text="Results"/>
                    <TextBox x:Name="SearchVideosCountTextBox" Grid.Row="1" Grid.Column="1" Height="32" Margin="0,8,0,0" Text="50" Width="120" HorizontalAlignment="Left"
                             VerticalContentAlignment="Center" Padding="8,2"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,8,0" Text="Min length (s)"/>
                    <TextBox x:Name="SearchVideosMinLenTextBox" Grid.Row="2" Grid.Column="1" Height="32" Margin="0,8,0,0" Text="0" Width="120" HorizontalAlignment="Left"
                             VerticalContentAlignment="Center" Padding="8,2"/>

                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="SearchVideosButton" Content="Search" MinWidth="110" Height="30" Click="SearchVideosButton_OnClick"/>
                        <TextBlock x:Name="SearchVideosStatusTextBlock" Margin="12,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Search playlists">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Query"/>
                    <TextBox x:Name="SearchPlaylistsQueryTextBox" Grid.Row="0" Grid.Column="1" Height="32" MinWidth="360" HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center" Padding="8,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,8,0" Text="Results"/>
                    <TextBox x:Name="SearchPlaylistsCountTextBox" Grid.Row="1" Grid.Column="1" Height="32" Margin="0,8,0,0" Text="20" Width="120" HorizontalAlignment="Left"
                             VerticalContentAlignment="Center" Padding="8,2"/>

                    <ListBox x:Name="SearchPlaylistsResultsListBox" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,8"
                             MouseDoubleClick="SearchPlaylistsResultsListBox_OnMouseDoubleClick"/>

                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,0">
                        <Button x:Name="SearchPlaylistsButton" Content="Search" MinWidth="110" Height="30" Click="SearchPlaylistsButton_OnClick"/>
                        <Button x:Name="ImportSelectedPlaylistButton" Content="Import selected" MinWidth="140" Height="30" Margin="8,0,0,0" Click="ImportSelectedPlaylistButton_OnClick"/>
                        <TextBlock x:Name="SearchPlaylistsStatusTextBlock" Margin="12,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Import playlist">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Playlist URL/ID"/>
                    <TextBox x:Name="ImportPlaylistUrlTextBox" Grid.Row="0" Grid.Column="1" Height="32" MinWidth="360" HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center" Padding="8,2"/>
                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="ImportPlaylistButton" Content="Import" MinWidth="110" Height="30" Click="ImportPlaylistButton_OnClick"/>
                        <TextBlock x:Name="ImportPlaylistStatusTextBlock" Margin="12,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="My playlists (best-effort)">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Requires yt-dlp cookies-from-browser. YouTube may block listing; if empty, paste a playlist URL in the Import tab." TextWrapping="Wrap"/>

                    <ListBox x:Name="AccountPlaylistsListBox" Grid.Row="1" Margin="0,12,0,8"
                             MouseDoubleClick="AccountPlaylistsListBox_OnMouseDoubleClick"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button x:Name="LoadAccountPlaylistsButton" Content="Load my playlists" MinWidth="140" Height="30" Click="LoadAccountPlaylistsButton_OnClick"/>
                        <Button x:Name="ImportSelectedAccountPlaylistButton" Content="Import selected" MinWidth="140" Height="30" Margin="8,0,0,0" Click="ImportSelectedAccountPlaylistButton_OnClick"/>
                        <TextBlock x:Name="AccountPlaylistsStatusTextBlock" Margin="12,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>
                    </TabControl>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0,12,12">
                    <Button Content="Close" MinWidth="110" Height="30" Click="CloseButton_OnClick"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>

