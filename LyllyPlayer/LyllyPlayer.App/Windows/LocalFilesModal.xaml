<Window x:Class="LyllyPlayer.Windows.LocalFilesModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:LyllyPlayer"
        Title="LyllyPlayer — Local files"
        Icon="pack://application:,,,/Assets/LyllyPlayer.ico"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Width="720"
        Height="460"
        MinWidth="600"
        MinHeight="420"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8,0,8,8"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
          UseLayoutRounding="True"
          local:RoundedChromeClip.IsEnabled="True">
        <Border Background="{DynamicResource App.Brush.WindowBg}"
                BorderThickness="0"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
        <Grid Margin="{DynamicResource App.Theme.WindowChromeContentMargin}">
            <Border SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                    UseLayoutRounding="True"
                    Background="{DynamicResource App.Brush.WindowBgImage.OptionsLog}"
                    CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
            <local:WindowChromeFrameRing Panel.ZIndex="5"
                                         SnapsToDevicePixels="True"
                                         StrokeWidth="{DynamicResource App.Theme.WindowChromeStrokeWidth}"
                                         OuterCornerRadius="8">
                <local:WindowChromeFrameRing.Style>
                    <Style TargetType="{x:Type local:WindowChromeFrameRing}">
                        <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderActive}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderInactive}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:WindowChromeFrameRing.Style>
            </local:WindowChromeFrameRing>

            <Grid Background="Transparent"
                  Panel.ZIndex="10"
                  LayoutTransform="{DynamicResource App.UiScaleTransform}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Custom top bar -->
                <Border x:Name="ChromeBar"
                        Grid.Row="0"
                        VerticalAlignment="Top"
                        Margin="{DynamicResource App.Theme.WindowBorderThicknessNegativeSides}"
                        Padding="{DynamicResource App.Theme.WindowChromeTitleBarPadding}"
                        CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuterTopOnly}"
                        SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                        UseLayoutRounding="True"
                        ClipToBounds="True"
                        Panel.ZIndex="999"
                        MouseLeftButtonDown="ChromeBar_OnMouseLeftButtonDown">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Height="28"
                          Margin="{DynamicResource App.Theme.WindowChromeTitleBarContentMargin}"
                          Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button x:Name="ChromeCloseButton" Grid.Column="1"
                                Width="34"
                                Height="24"
                                Margin="0,2,0,2"
                                Padding="0"
                                FontFamily="{StaticResource App.MonoFont}"
                                FontSize="12"
                                Content="[X]"
                                Click="ChromeCloseButton_OnClick">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="12,12,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <Button x:Name="AddFolderButton"
                                Content="Add folder…"
                                MinWidth="120"
                                Height="32"
                                Margin="0,0,8,0"
                                Click="AddFolderButton_OnClick"/>
                        <Button x:Name="AddFilesButton"
                                Content="Add files…"
                                MinWidth="120"
                                Height="32"
                                Click="AddFilesButton_OnClick"/>
                    </StackPanel>

                    <GroupBox Grid.Row="1"
                              Header="Import behavior"
                              Margin="0,12,0,0"
                              Foreground="{DynamicResource App.Theme.Foreground}"
                              BorderBrush="{DynamicResource App.Theme.Border}">
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="ReplaceRadio"
                                             GroupName="ImportBehavior"
                                             Content="Replace"
                                             Margin="0,0,14,0"
                                             Checked="ReplaceRadio_OnChecked"/>
                                <RadioButton x:Name="AppendRadio"
                                             GroupName="ImportBehavior"
                                             Content="Append"
                                             Checked="AppendRadio_OnChecked"/>
                            </StackPanel>
                            <CheckBox x:Name="RemoveDuplicatesCheckBox"
                                      Content="Remove duplicates (local: full path)"
                                      Checked="RemoveDuplicatesCheckBox_OnChecked"
                                      Unchecked="RemoveDuplicatesCheckBox_OnUnchecked"/>
                        </StackPanel>
                    </GroupBox>

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Padding="10"
                            CornerRadius="6"
                            Background="{DynamicResource App.Theme.SurfaceRaised}"
                            BorderBrush="{DynamicResource App.Theme.Border}"
                            BorderThickness="1">
                        <DockPanel LastChildFill="True">
                            <Button x:Name="CancelButton"
                                    DockPanel.Dock="Right"
                                    Content="Cancel"
                                    MinWidth="80"
                                    Height="28"
                                    Margin="8,0,0,0"
                                    Visibility="Collapsed"
                                    Click="CancelButton_OnClick"/>
                            <Button x:Name="SkipMetadataButton"
                                    DockPanel.Dock="Right"
                                    Content="Skip metadata"
                                    MinWidth="110"
                                    Height="28"
                                    Margin="8,0,0,0"
                                    Visibility="Collapsed"
                                    Click="SkipMetadataButton_OnClick"/>
                            <TextBlock x:Name="StatusTextBlock"
                                       Text="Ready."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource App.Theme.Foreground}"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

