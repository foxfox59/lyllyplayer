<Window x:Class="LyllyPlayer.Windows.LyricsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:LyllyPlayer"
        Title="LyllyPlayer — Lyrics"
        Icon="pack://application:,,,/Assets/LyllyPlayer.ico"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Width="700"
        Height="500"
        MinHeight="300"
        MinWidth="400"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Window.InputBindings>
        <KeyBinding Key="C" Modifiers="Control" Command="Copy"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="Copy" Executed="CopyCommand_Executed" CanExecute="CopyCommand_CanExecute"/>
    </Window.CommandBindings>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8,0,8,8"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
          UseLayoutRounding="True"
          local:RoundedChromeClip.IsEnabled="True">
        <!-- Layer 1: Opaque background border -->
        <Border Background="{DynamicResource App.Brush.WindowBg}"
                BorderThickness="0"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
        <!-- Layer 2: Background image -->
        <Grid Margin="{DynamicResource App.Theme.WindowChromeContentMargin}">
            <Border SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                    UseLayoutRounding="True"
                    Background="{DynamicResource App.Brush.WindowBgImage.Lyrics}"
                    CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
            <!-- Layer 3: Custom window border ring -->
            <local:WindowChromeFrameRing Panel.ZIndex="5"
                                         SnapsToDevicePixels="True"
                                         StrokeWidth="{DynamicResource App.Theme.WindowChromeStrokeWidth}"
                                         OuterCornerRadius="8">
                <local:WindowChromeFrameRing.Style>
                    <Style TargetType="{x:Type local:WindowChromeFrameRing}">
                        <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderActive}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderInactive}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:WindowChromeFrameRing.Style>
            </local:WindowChromeFrameRing>
            <!-- Layer 4: Actual content (ui-scaled, transparent) -->
            <Grid Background="Transparent"
                  Panel.ZIndex="10"
                  LayoutTransform="{DynamicResource App.UiScaleTransform}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom top bar -->
                <Border x:Name="ChromeBar"
                        Grid.Row="0"
                        VerticalAlignment="Top"
                        Margin="{DynamicResource App.Theme.WindowBorderThicknessNegativeSides}"
                        Padding="{DynamicResource App.Theme.WindowChromeTitleBarPadding}"
                        CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuterTopOnly}"
                        SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                        UseLayoutRounding="True"
                        ClipToBounds="True"
                        Panel.ZIndex="999"
                        MouseLeftButtonDown="ChromeBar_OnMouseLeftButtonDown">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarInactive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Height="28"
                          Margin="{DynamicResource App.Theme.WindowChromeTitleBarContentMargin}"
                          Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button x:Name="ChromeCloseButton" Grid.Column="1"
                                Width="34"
                                Height="24"
                                Margin="0,2,0,2"
                                Padding="0"
                                FontFamily="{StaticResource App.MonoFont}"
                                FontSize="12"
                                Content="[X]"
                                Click="ChromeCloseButton_OnClick">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Body -->
                <Grid Grid.Row="1" Margin="{DynamicResource App.Theme.WindowChromeBodyInsetMargin}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Status label showing resolved title or status message -->
                    <Label x:Name="LyricsTitleLabel"
                           Grid.Row="0"
                           Margin="12,12,12,8"
                           Padding="8,6"
                           Content="Lyrics not available"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Theme.Foreground}"
                           Background="Transparent"
                           BorderThickness="0"/>

                    <!-- Lyrics ListBox -->
                    <ListBox x:Name="LyricsListBox"
                             Grid.Row="1"
                             Margin="12,0,12,8"
                             Background="{DynamicResource App.Theme.Surface}"
                             BorderThickness="0"
                             VirtualizingStackPanel.IsVirtualizing="False"
                             VirtualizingStackPanel.VirtualizationMode="Standard"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.IsDeferredScrollingEnabled="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Focusable="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Padding="6,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Theme.Hover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Theme.Pressed}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Theme.Foreground}"/>
                                        <Setter Property="BorderThickness" Value="0,1,0,1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Foreground}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="12">
                        <Button x:Name="CopyButton"
                                Content="Copy"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Padding="18,6"
                                MinWidth="80"
                                Click="CopyButton_OnClick"
                                Background="{DynamicResource App.Theme.SurfaceRaised}"
                                BorderBrush="{DynamicResource App.Theme.Border}"
                                BorderThickness="1"
                                Foreground="{DynamicResource App.Theme.Foreground}"/>
                        <Button x:Name="CloseButton"
                                Content="Close"
                                VerticalAlignment="Center"
                                Padding="18,6"
                                MinWidth="80"
                                Click="CloseButton_OnClick"
                                Background="{DynamicResource App.Theme.SurfaceRaised}"
                                BorderBrush="{DynamicResource App.Theme.Border}"
                                BorderThickness="1"
                                Foreground="{DynamicResource App.Theme.Foreground}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
