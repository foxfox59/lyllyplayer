<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Version>2.7.0</Version>
    <AssemblyTitle>LyllyPlayer</AssemblyTitle>
    <Product>LyllyPlayer</Product>
    <Company>MuiluFox</Company>
    <Description>LyllyPlayer music player</Description>
    <PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
    <OutputType>WinExe</OutputType>
    <!-- net8.0-windows: WPF on Windows 10+. Local build/run uses the shared runtime if installed (no bundled runtime). -->
    <!-- Shipping to bare Windows (no .NET SDK/runtime): only dotnet publish with Win10-SelfContained.pubxml or repo-root publish-win10-selfcontained.cmd. -->
    <!-- Versioned TFM: WinRT (SMTC). LibVLCSharp also references WindowsAppSDK on this TFM — bootstrap disabled below. -->
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <WindowsAppSdkBootstrapInitialize>false</WindowsAppSdkBootstrapInitialize>
    <EnableMsixTooling>false</EnableMsixTooling>
    <WindowsPackageType>None</WindowsPackageType>
    <EnableCoreMrtTooling>false</EnableCoreMrtTooling>
    <EnableDefaultWindowsAppSdkContentItems>false</EnableDefaultWindowsAppSdkContentItems>
    <EnableDefaultWindowsAppSdkPRIResourceItems>false</EnableDefaultWindowsAppSdkPRIResourceItems>
    <AppxGeneratePriEnabled>false</AppxGeneratePriEnabled>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>LyllyPlayer</AssemblyName>
    <RootNamespace>LyllyPlayer</RootNamespace>
    <ApplicationIcon>Assets\LyllyPlayer.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Keep DPI behavior declared in app.manifest; suppress SDK warning about alternative configuration paths. -->
    <NoWarn>$(NoWarn);WFAC010</NoWarn>
  </PropertyGroup>

  <!-- Debug: separate obj/bin trees (avoids MSB3026 when something locks the default bin\Debug\… output).
       UseAppHost=true so the output includes LyllyPlayer.exe — `dotnet run` and Task Manager show the app name, not only ".NET Host". -->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <UseAppHost>true</UseAppHost>
    <OutputPath>bin\DebugDev\net8.0-windows\</OutputPath>
    <IntermediateOutputPath>obj\DebugDev\net8.0-windows\</IntermediateOutputPath>
  </PropertyGroup>

  <!-- Release (no PublishProfile): native apphost + same assembly metadata as Debug. -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release' And '$(PublishProfile)' == ''">
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\LyllyPlayer.Core\LyllyPlayer.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Satisfy LibVLCSharp's dependency without injecting bootstrap auto-init at startup -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.5.240627000">
      <ExcludeAssets>all</ExcludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="2.0.1" />
    <PackageReference Include="LibVLCSharp" Version="3.9.2" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="NAudio.Lame" Version="2.0.1" />
    <PackageReference Include="taglib-sharp-netstandard2.0" Version="2.1.0" />
    <PackageReference Include="VideoLAN.LibVLC.Windows" Version="3.0.21" />
  </ItemGroup>

  <ItemGroup>
    <!-- Ensure .ico is packaged so Window Icon can load it -->
    <Resource Include="Assets\LyllyPlayer.ico" />
    <Resource Include="Assets\Background.png" />
    <Resource Include="Assets\BackgroundMeowCat.jpg" />
    <Resource Include="Assets\icon-128.png" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\icon-128.png" CopyToOutputDirectory="PreserveNewest" />
    <!-- LAME (LGPL) + NAudio.Lame (MIT) — ship next to the exe for binary distributions -->
    <Content Include="..\..\docs\THIRD_PARTY_NOTICES.md" Link="THIRD_PARTY_NOTICES.md" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
