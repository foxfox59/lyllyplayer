<?xml version="1.0" encoding="utf-8"?>
<!--
  Supported Windows ship build: bundles .NET 8 — target PC needs only Windows 10+ x64 (no .NET SDK, no Desktop Runtime).
  WPF still loads OS and self-extracted native runtime bits; this is the minimal practical “no separate .NET install” layout.
  End-user still supplies ffmpeg and yt-dlp (paths in app settings or PATH).

  Publish from repo root:
    dotnet publish LyllyPlayer\LyllyPlayer.App\LyllyPlayer.App.csproj -c Release -p:PublishProfile=Win10-SelfContained

  Output: LyllyPlayer\LyllyPlayer.App\bin\Release\net8.0-windows\win-x64\publish\
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <!-- Single-file publish requires the managed apphost stub; overrides Release no-apphost compile defaults in the .csproj -->
    <UseAppHost>true</UseAppHost>
    <!-- Bundle runtime; do not rely on shared Desktop Runtime on the machine -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- WPF + reflection: trimming breaks at runtime — keep off -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
