<Window x:Class="LyllyPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LyllyPlayer"
        mc:Ignorable="d"
        Title="LyllyPlayer"
        Icon="pack://application:,,,/Assets/LyllyPlayer.ico"
        Background="Transparent"
        ShowInTaskbar="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        SizeToContent="Height"
        Width="600"
        MinWidth="600"
        MaxWidth="600">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
          UseLayoutRounding="True"
          local:RoundedChromeClip.IsEnabled="True">
        <Border Background="{DynamicResource App.Brush.WindowBg}"
                BorderThickness="0"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
        <Grid Margin="{DynamicResource App.Theme.WindowChromeContentMargin}">
            <Border x:Name="MainWindowImageBackgroundBorder"
                    SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                    UseLayoutRounding="True"
                    Background="{DynamicResource App.Brush.WindowBgImage.Main}"
                    CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuter}"/>
            <local:WindowChromeFrameRing Panel.ZIndex="5"
                                         SnapsToDevicePixels="True"
                                         StrokeWidth="{DynamicResource App.Theme.WindowChromeStrokeWidth}"
                                         OuterCornerRadius="8">
                <local:WindowChromeFrameRing.Style>
                    <Style TargetType="{x:Type local:WindowChromeFrameRing}">
                        <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderActive}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="RingBrush" Value="{DynamicResource App.Theme.WindowBorderInactive}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:WindowChromeFrameRing.Style>
            </local:WindowChromeFrameRing>
            <Grid Background="Transparent"
                  Panel.ZIndex="10"
                  LayoutTransform="{DynamicResource App.UiScaleTransform}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Custom top bar -->
        <Border x:Name="ChromeBar"
                Grid.Row="0"
                VerticalAlignment="Top"
                Margin="{DynamicResource App.Theme.WindowBorderThicknessNegativeSides}"
                Padding="{DynamicResource App.Theme.WindowChromeTitleBarPadding}"
                CornerRadius="{DynamicResource App.Theme.WindowCornerRadiusOuterTopOnly}"
                SnapsToDevicePixels="{DynamicResource App.Theme.WindowChromeSnapsToDevicePixels}"
                UseLayoutRounding="True"
                ClipToBounds="True"
                Panel.ZIndex="999"
                PreviewMouseLeftButtonDown="ChromeBar_OnPreviewMouseLeftButtonDown"
                PreviewMouseLeftButtonUp="ChromeBar_OnPreviewMouseLeftButtonUp">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarActive}"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                <Condition Binding="{Binding IsAlwaysOnTopUi, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource App.Theme.TitleBarInactive}"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Height="28"
                  Margin="{DynamicResource App.Theme.WindowChromeTitleBarContentMargin}"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ChromeTitleText"
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                        <Condition Binding="{Binding IsAlwaysOnTopUi, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button x:Name="ChromeCompactLayoutButton"
                        Grid.Column="1"
                        Width="34"
                        Height="24"
                        Margin="0,2,4,2"
                        Padding="0"
                        Content="[-]"
                        FontFamily="{StaticResource App.MonoFont}"
                        FontSize="12"
                        Click="ChromeCompactLayoutButton_OnClick">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                        <Condition Binding="{Binding IsAlwaysOnTopUi, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <ToggleButton x:Name="ChromeAlwaysOnTopToggleButton"
                              Grid.Column="2"
                              Width="44"
                              Height="24"
                              Margin="0,2,4,2"
                              Padding="0"
                              Content="TOP"
                              FontFamily="{StaticResource App.MonoFont}"
                              FontSize="12"
                              Checked="ChromeAlwaysOnTopToggleButton_OnChecked"
                              Unchecked="ChromeAlwaysOnTopToggleButton_OnUnchecked">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource App.ChromeTitleBarToggleButton}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                        <Condition Binding="{Binding IsAlwaysOnTopUi, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </MultiDataTrigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource App.Theme.Selection}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.SelectionBorder}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.SelectionText}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <Button Grid.Column="3"
                        Width="34"
                        Height="24"
                        Margin="0,2,0,2"
                        Padding="0"
                        FontFamily="{StaticResource App.MonoFont}"
                        FontSize="12"
                        Content="[X]"
                        Click="ChromeCloseButton_OnClick">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource App.ChromeTitleBarButton}">
                            <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextActive}"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                        <Condition Binding="{Binding IsAlwaysOnTopUi, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{DynamicResource App.Theme.TitleBarTextInactive}"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid x:Name="MainChromeBodyWrapGrid" Grid.Row="1" Margin="{DynamicResource App.Theme.WindowChromeBodyInsetMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Top: Tools -->
        <Grid x:Name="MainToolsRowGrid" Grid.Row="0" Margin="12,12,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="OptionsButton"
                    Grid.Column="0"
                    Content="options&#x2026;"
                    MinWidth="70"
                    Padding="10,2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="OptionsButton_OnClick"/>

            <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button x:Name="PlaylistToolsButton"
                        Content="playlist&#x2026;"
                        MinWidth="70"
                        Padding="10,2"
                        VerticalAlignment="Top"
                        Click="PlaylistToolsButton_OnClick"/>
                <Button x:Name="LyricsButton"
                        Content="lyrics&#x2026;"
                        MinWidth="70"
                        Padding="10,2"
                        VerticalAlignment="Top"
                        Visibility="Collapsed"
                        Click="LyricsButton_OnClick"/>
            </StackPanel>
        </Grid>

        <!-- Middle: Visualizer + now playing + transport (single themed card) -->
        <Grid x:Name="MainPlaybackCardOuterGrid" Grid.Row="1" Margin="12,0,12,8">
            <Border x:Name="MainPlaybackCardBorder"
                    CornerRadius="6"
                    SnapsToDevicePixels="True"
                    Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                    BorderBrush="{DynamicResource App.Theme.Border}"
                    BorderThickness="1">
                <Grid x:Name="PlaybackCardInnerGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="VisualizerBorder"
                                Grid.Column="0"
                                Padding="10,8,6,0"
                                Background="Transparent"
                                MouseLeftButtonUp="VisualizerBorder_OnMouseLeftButtonUp">
                            <!-- Fixed-size inner area so VU / spectrum / off do not shift layout -->
                            <Grid x:Name="VisualizerHostGrid" Height="26" VerticalAlignment="Center" Margin="0,0,0,0"
                                  SizeChanged="VisualizerHostGrid_OnSizeChanged">
                                <!-- Subtle outline so the visualizer reads as a surface in all modes -->
                                <Border x:Name="VisualizerHostOutline"
                                        BorderBrush="{DynamicResource App.Theme.Border}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Background="Transparent"
                                        Opacity="0.65"
                                        SnapsToDevicePixels="True"
                                        IsHitTestVisible="False"/>
                                <Grid x:Name="VuGrid" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                <TextBlock x:Name="VuMeterLeftLabel"
                                           Text="L"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           Foreground="{DynamicResource App.Theme.ForegroundSubtle}"/>
                                <ProgressBar x:Name="VuLeftBar"
                                             Grid.Column="1"
                                             Style="{StaticResource App.ProgressBar.Vu}"
                                             Background="{DynamicResource App.Theme.Surface}"
                                             Foreground="{DynamicResource App.Theme.Foreground}"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="0"
                                             Margin="0,0,12,0"/>
                                <TextBlock x:Name="VuMeterRightLabel"
                                           Text="R"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           Foreground="{DynamicResource App.Theme.ForegroundSubtle}"/>
                                <ProgressBar x:Name="VuRightBar"
                                             Grid.Column="3"
                                             Style="{StaticResource App.ProgressBar.Vu}"
                                             Background="{DynamicResource App.Theme.Surface}"
                                             Foreground="{DynamicResource App.Theme.Foreground}"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="0"/>
                            </Grid>

                            <Border x:Name="SpectrumPanelChrome"
                                    Height="26"
                                    VerticalAlignment="Bottom"
                                    Visibility="Collapsed"
                                    CornerRadius="0"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource App.Theme.Border}"
                                    Background="{DynamicResource App.Theme.SpectrumPanelBackground}"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="True">
                                <Canvas x:Name="SpectrumCanvas"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="Transparent"/>
                            </Border>

                            <!-- Ultra-compact seek overlay: subtle progress fill + slim thumb (non-interactive; click handling is on VisualizerBorder). -->
                            <Canvas x:Name="UltraSeekOverlayCanvas"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="Transparent">
                                <!-- Fill -->
                                <Rectangle x:Name="UltraSeekFillRect"
                                           Canvas.Left="0"
                                           Canvas.Top="0"
                                           Height="26"
                                           Width="0"
                                           Fill="{DynamicResource App.Theme.ForegroundSubtle}"
                                           Opacity="0.18"/>
                                <!-- Thumb: thin line at the right edge of the fill -->
                                <Rectangle x:Name="UltraSeekThumbRect"
                                           Canvas.Left="0"
                                           Canvas.Top="3"
                                           Width="2"
                                           Height="20"
                                           Fill="{DynamicResource App.Theme.Foreground}"
                                           Opacity="0.55"/>
                            </Canvas>
                        </Grid>
                    </Border>

                        <!-- (Ultra compact) PL is shown on the transport row, not here. -->
                    </Grid>

                    <Border x:Name="CardDividerAboveInfoBorder"
                            Grid.Row="1" Height="1" VerticalAlignment="Center" Background="{DynamicResource App.Theme.Border}" Margin="10,0,10,0" SnapsToDevicePixels="True"/>

                    <StackPanel x:Name="MainPlaybackInfoStack" Grid.Row="2" Margin="10,8,10,8">
                        <TextBlock x:Name="PlaylistTitleTextBlock"
                                   Text="(no playlist)"
                                   FontSize="12"
                                   Foreground="{DynamicResource App.Theme.Foreground}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,2"
                                   Padding="2,0,2,0"
                                   Background="Transparent">
                            <TextBlock.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open origin" Click="PlaylistTitle_OpenOriginMenuItem_OnClick"/>
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NowPlayingTextBlock"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       TextTrimming="CharacterEllipsis">
                                <Run x:Name="NowPlayingStatusRun" Text="[STOPPED] " Foreground="{DynamicResource App.Theme.ForegroundSubtle}"/>
                                <Run x:Name="NowPlayingTitleRun" Text="Not playing"/>
                            </TextBlock>
                            <Button x:Name="CompactPlaylistButton"
                                    Grid.Column="1"
                                    Width="34"
                                    Height="22"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    Content="PL"
                                    FontFamily="{StaticResource App.MonoFont}"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"
                                    Click="CompactPlaylistButton_OnClick"/>
                        </Grid>

                        <Grid x:Name="SeekTimeRowGrid" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ElapsedTextBlock"
                                       Grid.Column="0"
                                       Text="0:00"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Slider x:Name="SeekSlider"
                                    Grid.Column="1"
                                    Style="{StaticResource App.Slider.Seek}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0"
                                    IsEnabled="False"
                                    VerticalAlignment="Center"
                                    PreviewMouseLeftButtonDown="SeekSlider_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="SeekSlider_OnPreviewMouseLeftButtonUp"
                                    PreviewMouseMove="SeekSlider_OnPreviewMouseMove"
                                    ValueChanged="SeekSlider_OnValueChanged"/>
                            <TextBlock x:Name="DurationTextBlock"
                                       Grid.Column="2"
                                       Text="--:--"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <Border x:Name="CardDividerAboveTransportBorder"
                            Grid.Row="3" Height="1" VerticalAlignment="Center" Background="{DynamicResource App.Theme.Border}" Margin="10,0,10,0" SnapsToDevicePixels="True"/>

                    <!-- Transport + volume; compact mode reparents VisualizerBorder into column 1 (between buttons and volume). -->
                    <Grid x:Name="TransportVolumeRowGrid" Grid.Row="4" Margin="10,8,10,10" ClipToBounds="False" UseLayoutRounding="True">
                        <Grid.ColumnDefinitions>
                            <!-- Use Auto+spacer+Auto to avoid subtle clipping when the left StackPanel is constrained by a star column. -->
                            <ColumnDefinition Width="Auto" MinWidth="0"/>
                            <ColumnDefinition Width="*" MinWidth="0"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Single line: sized to fit fixed window width (600) with * + Auto columns; slightly smaller type + padding. -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0"
                                    TextElement.FontSize="11">
                            <Button x:Name="PrevButton" Content="&lt;&lt;" MinWidth="40" Margin="0,0,6,0" Padding="6,4" Click="PrevButton_OnClick"/>
                            <Button x:Name="StopButton" Content="■" MinWidth="40" Margin="0,0,6,0" Padding="6,4" Click="StopButton_OnClick"/>
                            <Button x:Name="PlayPauseButton" Content="&gt;" MinWidth="40" Margin="0,0,6,0" Padding="6,4" Click="PlayPauseButton_OnClick"/>
                            <Button x:Name="NextButton" Content="&gt;&gt;" MinWidth="40" Margin="0,0,6,0" Padding="6,4" Click="NextButton_OnClick"/>

                            <ToggleButton x:Name="CompactShuffleToggleButton"
                                          Width="26"
                                          Height="24"
                                          Margin="0,0,6,0"
                                          Padding="0"
                                          FontFamily="{StaticResource App.MonoFont}"
                                          FontSize="12"
                                          Visibility="Collapsed"
                                          Checked="CompactShuffleToggleButton_OnChecked"
                                          Unchecked="CompactShuffleToggleButton_OnUnchecked">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="FocusVisualStyle" Value="{StaticResource App.FocusVisual.Theme}"/>
                                        <Setter Property="Content" Value="s"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Theme.Foreground}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource App.Theme.Border}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          RecognizesAccessKey="True"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Theme.Hover}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Theme.Pressed}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                                <Setter Property="Content" Value="S"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <Button x:Name="CompactRepeatButton"
                                    Content="r"
                                    Width="26"
                                    Height="24"
                                    Margin="0,0,6,0"
                                    Padding="0"
                                    FontFamily="{StaticResource App.MonoFont}"
                                    FontSize="12"
                                    Visibility="Collapsed"
                                    Click="CompactRepeatButton_OnClick"/>

                            <ToggleButton x:Name="ShuffleToggle"
                                          Content="Shuffle OFF"
                                          Style="{StaticResource App.FlatToggleButton}"
                                          MinWidth="96"
                                          Margin="4,0,6,0"
                                          Padding="6,4"
                                          FontSize="11"
                                          Checked="ShuffleToggle_OnChecked"
                                          Unchecked="ShuffleToggle_OnUnchecked"/>

                            <Button x:Name="RepeatButton"
                                    Content="Repeat: None"
                                    MinWidth="96"
                                    Margin="0,0,2,0"
                                    Padding="6,4"
                                    FontSize="11"
                                    HorizontalAlignment="Left"
                                    Click="RepeatButton_OnClick"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Panel.ZIndex="1">
                            <TextBlock x:Name="VolumeLabelTextBlock" Text="Vol" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="{DynamicResource App.Theme.Foreground}"/>
                            <Slider x:Name="VolumeSlider"
                                    Width="90"
                                    HorizontalAlignment="Left"
                                    HorizontalContentAlignment="Left"
                                    ClipToBounds="True"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0.85"
                                    SmallChange="0.02"
                                    LargeChange="0.10"
                                    ValueChanged="VolumeSlider_OnValueChanged"/>
                            <Button x:Name="LyricsUltraButtonInline"
                                    Width="34"
                                    Height="22"
                                    Margin="0,0,4,0"
                                    Padding="0"
                                    Content="L"
                                    FontFamily="{StaticResource App.MonoFont}"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"
                                    Click="LyricsUltraButtonInline_OnClick"/>
                            <Button x:Name="CompactPlaylistButtonInline"
                                    Width="34"
                                    Height="22"
                                    Margin="0,0,0,0"
                                    Padding="0"
                                    Content="PL"
                                    FontFamily="{StaticResource App.MonoFont}"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"
                                    Click="CompactPlaylistButton_OnClick"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>
